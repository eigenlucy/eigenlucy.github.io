{%- comment -%}
  Reusable gallery card. Include with: {% include gallery_card.liquid item=item %}
  Item fields: file, type (image/video), caption, tags (array), path (optional override)
{%- endcomment -%}

{%- assign tag_list = item.tags | join: ', ' -%}
{%- if tag_list != '' -%}
  {%- assign all_tags = tag_list | append: ', ' | append: item.type -%}
{%- else -%}
  {%- assign all_tags = item.type -%}
{%- endif -%}

<div class="col-md-3 card-item" data-tags="{{ all_tags | downcase }}">
  <div class="card mb-4 shadow-sm">
    {%- if item.type == 'image' -%}
      {%- if item.path -%}
        {%- assign media_path = item.path -%}
      {%- else -%}
        {%- assign media_path = 'assets/img/Gallery/' | append: item.file -%}
      {%- endif -%}
      {% include figure.liquid loading=include.loading path=media_path class="img-fluid rounded z-depth-1" %}
    {%- elsif item.type == 'video' -%}
      {%- if item.path -%}
        {%- assign media_path = item.path -%}
      {%- else -%}
        {%- assign media_path = 'assets/video/' | append: item.file -%}
      {%- endif -%}
      {% include video.liquid loading=include.loading path=media_path class="img-fluid rounded z-depth-1" type="video/mp4" controls=true %}
    {%- endif -%}
    {%- if item.caption and item.caption != '' -%}
      <div class="card-body">
        <p class="card-text">{{ item.caption }}</p>
        <div class="d-flex justify-content-between align-items-center">
        </div>
      </div>
    {%- endif -%}
  </div>
</div>
